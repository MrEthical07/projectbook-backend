# SuperAPI environment example
# Copy this to .env and choose one mode.

# ==========================================
# MODE A: Lean feature mode (core stores still required)
# ==========================================
# APP_PROFILE=minimal
# APP_ENV=dev
# HTTP_ADDR=:8080
# AUTH_ENABLED=false
# RATELIMIT_ENABLED=false
# CACHE_ENABLED=false
# PERMISSIONS_ENABLED=false

# ==========================================
# MODE B: Full mode (Postgres + Redis + Mongo + Auth)
# ==========================================
APP_PROFILE=dev
APP_ENV=dev
HTTP_ADDR=:8080

# CORS
# - allowedOrigins: comma-separated browser origins to allow.
# - denyOrigins: optional comma-separated origins to explicitly block.
# - Localhost origins are allowed by default unless listed in denyOrigins.


allowedOrigins=http://localhost:5173,http://localhost:4173
# denyOrigins=https://blocked.example.com
# Legacy aliases still supported:


# HTTP_MIDDLEWARE_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
# HTTP_MIDDLEWARE_CORS_DENY_ORIGINS=https://blocked.example.com

POSTGRES_ENABLED=true
POSTGRES_URL=postgres://projectbook:projectbook@127.0.0.1:5432/projectbook?sslmode=disable
# DATABASE_URL=postgres://projectbook:projectbook@127.0.0.1:5432/projectbook?sslmode=disable

REDIS_ENABLED=true
REDIS_ADDR=127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379/0

MONGO_ENABLED=true
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=projectbook

AUTH_ENABLED=true
AUTH_MODE=hybrid
PROJECTBOOK_PERMISSION_CONTEXT_SECRET=REPLACE_WITH_96_HEX_PERMISSION_CONTEXT_SECRET

EMAIL_ENABLED=true
RESEND_API_KEY=re_REPLACE_ME
WEB_APP_BASE_URL=http://localhost:5173
TRANSACTIONAL_SENDER_EMAIL=no-reply@projectbook.dev
TRANSACTIONAL_SENDER_NAME=no-reply
VERIFICATION_SENDER_EMAIL=verify@projectbook.dev
VERIFICATION_SENDER_NAME=ProjectBook Verify
PASSWORD_RESET_SENDER_EMAIL=security@projectbook.dev
PASSWORD_RESET_SENDER_NAME=ProjectBook Security
PASSWORD_CHANGE_SENDER_EMAIL=security@projectbook.dev
PASSWORD_CHANGE_SENDER_NAME=ProjectBook Security

RATELIMIT_ENABLED=true
RATELIMIT_FAIL_OPEN=true

CACHE_ENABLED=true
CACHE_FAIL_OPEN=true

PERMISSIONS_ENABLED=true

# Metrics are disabled by default via env; enable only if needed.
METRICS_ENABLED=false
METRICS_AUTH_TOKEN=REPLACE_WITH_96_HEX_METRICS_TOKEN

# Optional production hardening
# TRACING_ENABLED=true
# TRACING_OTLP_ENDPOINT=collector:4317
