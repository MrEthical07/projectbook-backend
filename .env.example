# SuperAPI environment example
# Copy this to .env and choose one mode.

# ==========================================
# MODE A: Lean feature mode (core stores still required)
# ==========================================
# APP_PROFILE=minimal
# APP_ENV=dev
# HTTP_ADDR=:8080
# AUTH_ENABLED=false
# RATELIMIT_ENABLED=false
# CACHE_ENABLED=false
# PERMISSIONS_ENABLED=false

# ==========================================
# MODE B: Full mode (Postgres + Redis + Mongo + Auth)
# ==========================================
APP_PROFILE=dev
APP_ENV=dev
HTTP_ADDR=:8080

POSTGRES_ENABLED=true
POSTGRES_URL=postgres://superapi:superapi@127.0.0.1:5432/superapi?sslmode=disable
# DATABASE_URL=postgres://superapi:superapi@127.0.0.1:5432/superapi?sslmode=disable

REDIS_ENABLED=true
REDIS_ADDR=127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379/0

MONGO_ENABLED=true
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=projectbook

AUTH_ENABLED=true
AUTH_MODE=hybrid
PROJECTBOOK_PERMISSION_CONTEXT_SECRET=VGZC4C7SIq4pgwIQeOOeK6JeJbIelxwjQ5uAjpK6J2EiDojYv2H3VJ6LXwDd3JHs

RATELIMIT_ENABLED=true
RATELIMIT_FAIL_OPEN=true

CACHE_ENABLED=true
CACHE_FAIL_OPEN=true

PERMISSIONS_ENABLED=true

# Optional production hardening (recommended in prod only)
# METRICS_ENABLED=true
# METRICS_AUTH_TOKEN=replace-with-strong-token
